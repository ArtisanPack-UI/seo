# Ignore all test, documentation, and development files with "export-ignore".

# Git and IDE files
/.git               export-ignore
/.gitattributes     export-ignore
/.gitignore         export-ignore
/.gitlab            export-ignore
/.gitlab-ci.yml     export-ignore
/.idea              export-ignore
/.claude            export-ignore

# OS files
.DS_Store           export-ignore

# Testing
/tests              export-ignore
/phpunit.xml        export-ignore
/src/**/Tests       export-ignore
/src/**/*Test.php   export-ignore
/src/**/Test.php    export-ignore

# Code quality tools
/.php-cs-fixer.cache      export-ignore
/.php-cs-fixer.dist.php   export-ignore
/phpcs.xml                export-ignore

# Documentation and contribution files
/docs               export-ignore
/CHANGELOG.md       export-ignore
/CONTRIBUTING.md    export-ignore
/.coderabbit.yaml   export-ignore

# Dependency lock file
/composer.lock      export-ignore

# Vendor directory (users install via Composer)
/vendor             export-ignore
